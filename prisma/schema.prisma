// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PropertyPurpose {
  venda
  aluguel
}

enum PropertyType {
  casa
  apartamento
  terreno
  rural
  comercial
}

enum PropertyCity {
  corumba
  ladario
}

enum PropertyStatus {
  disponivel
  reservado
  vendido
  alugado
}

enum UserRole {
  admin
  user
}

model User {
  id                  String            @id @default(cuid())
  email               String            @unique
  passwordHash        String

  role                UserRole          @default(user)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([email])
}

model Property {
  id                  String            @id @default(cuid())
  slug                String            @unique
  title               String

  purpose             PropertyPurpose
  type                PropertyType

  city                PropertyCity
  /// `corumba` | `ladario` (mantido no banco para facilitar filtros/URL sem depender de enum).
  citySlug            String
  neighborhood        String

  /// Valor em BRL em centavos? Aqui mantemos inteiro (ex.: 380000 = R$ 380.000).
  /// Se você quiser centavos, ajustamos para `Int` em centavos ou para `Decimal`.
  price               Int
  priceSuffix        String?
  priceNote          String?

  shortDescription   String
  longDescription    String

  bedrooms           Int?
  bathrooms          Int?
  parkingSpaces      Int?

  totalArea          Int
  builtArea          Int?

  coverImageUrl      String

  featured           Boolean           @default(false)
  specialOpportunity Boolean          @default(false)
  tags               String[]

  status             PropertyStatus    @default(disponivel)
  whatsappMessage    String

  images             PropertyImage[]
  leads              Lead[]

  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  @@index([status])
  @@index([citySlug])
  @@index([purpose])
  @@index([type])
}

model PropertyImage {
  id          String   @id @default(cuid())
  /// Ordem da galeria (0..n). Ajuda a manter a sequência de thumbnails.
  sortOrder   Int      @default(0)

  src         String
  alt         String
  width       Int
  height      Int

  propertyId  String
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([propertyId, sortOrder])
}

enum LeadChannel {
  whatsapp
  telefone
  email
  formulario
}

model Lead {
  id          String      @id @default(cuid())
  name        String
  phone       String?
  email       String?
  message     String
  channel     LeadChannel @default(formulario)

  /// Se o lead vier de um imóvel específico.
  propertyId  String?
  property    Property?   @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  createdAt   DateTime    @default(now())

  @@index([createdAt])
  @@index([propertyId])
}
